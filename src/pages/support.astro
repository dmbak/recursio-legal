---
import LegalLayout from '../layouts/LegalLayout.astro';
---

<LegalLayout
  title="Support — Recursio"
  description="Contact Recursio support for help with your account, subscriptions, or learning data."
  canonicalSlug="support"
>
  <article class="legal-section">
    <h1>Recursio Support</h1>

    <p class="page-intro">If you need help with Recursio, contact support.</p>

    <a href="mailto:support@recursio.app" class="email-link">support@recursio.app</a>

    <h2>Support Topics</h2>
    <ul class="support-topics">
      <li>Account access</li>
      <li>Apple or Google sign-in</li>
      <li>Subscription restore</li>
      <li>AI turn limits</li>
      <li>Vocabulary or progress issues</li>
      <li>Account deletion</li>
    </ul>

    <h2>Subscription &amp; Billing Issues</h2>
    <p>
      Subscription billing is handled by the App Store or Google Play. If you need a refund, use
      the refund tools provided by Apple or Google.
    </p>

    <h2>Account Deletion</h2>
    <p>
      To request deletion of your account and learning data, visit the
      <a href="/delete-account">Delete Account</a> page.
    </p>

    <h2>Legal</h2>
    <ul>
      <li><a href="/privacy">Privacy Policy</a></li>
      <li><a href="/terms">Terms of Use</a></li>
      <li><a href="/subscription-terms">Subscription Terms</a></li>
    </ul>
  </article>
</LegalLayout>
